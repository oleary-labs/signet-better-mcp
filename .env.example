# ---- Better Auth (runs in-process) ----------------------------------------
# Secret for signing cookies/tokens. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# SQLite database path. For Railway with persistent disk, use /data/auth.db
# DATABASE_URL=file:./data/auth.db

# ---- Social providers -----------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Signet ---------------------------------------------------------------
# Group contract address (0x...). Lowercased.
SIGNET_GROUP_ID=

# Bootstrap node URLs in the group. Comma-separated.
SIGNET_NODE_URLS=http://54.90.227.156:8080,http://44.214.181.89:8080,http://44.205.254.164:8080

# ---- ZK prover / bundler --------------------------------------------------
SIGNET_PROVER_URL=http://signet-min-bundler.railway.internal:4337/v1/prove
SIGNET_BUNDLER_API_KEY=

# ---- Chain RPC (JSON map of chainId -> URL) --------------------------------
# SIGNET_RPC_URLS={"8453":"https://mainnet.base.org"}

# ---- This service ---------------------------------------------------------
PORT=4100
PUBLIC_URL=https://signet-testnet-auth.olearylabs.com
