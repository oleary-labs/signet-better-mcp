# ---- Better Auth (runs in-process) ----------------------------------------
# Secret for signing cookies/tokens. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# SQLite database path. Defaults to file:./data/auth.db
# DATABASE_URL=file:./data/auth.db

# ---- Social providers -----------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Signet ---------------------------------------------------------------
# Group contract address (0x...). Lowercased.
SIGNET_GROUP_ID=

# Bootstrap node URLs in the group. Comma-separated. The session is registered
# on all of them in parallel via authenticateWithBootstrap().
SIGNET_NODE_URLS=http://localhost:8080,http://localhost:8081,http://localhost:8082

# ---- ZK prover ------------------------------------------------------------
# Server-side proof generation endpoint. The signet-sdk's generateServerProof()
# POSTs { jwt, session_pub } here and expects { proof, sub, iss, exp, aud, azp,
# jwks_modulus, session_pub } back.
SIGNET_PROVER_URL=http://localhost:5400/v1/prove

# ---- This service ---------------------------------------------------------
PORT=4100
PUBLIC_URL=http://localhost:4100
